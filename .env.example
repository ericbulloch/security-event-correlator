# Run scripts/seed_dev.py after first boot to generate a real key
DEV_API_KEY=

# Admin user seeded by scripts/seed_dev.py
DEV_ADMIN_USERNAME=admin
DEV_ADMIN_PASSWORD=change-me-in-production

# JWT — required for human (frontend) authentication
# Generate a strong secret: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480

# CORS — comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:5173

# PostgreSQL credentials — used by docker-compose.yml
POSTGRES_DB=security_events
POSTGRES_USER=sec_user
POSTGRES_PASSWORD=change-me-do-not-use-this-in-production

# RabbitMQ credentials — used by docker-compose.yml
RABBITMQ_USER=sec_user
RABBITMQ_PASSWORD=change-me-do-not-use-this-in-production

# Database — for local development outside Docker, update host/port as needed
DATABASE_URL=postgresql://sec_user:change-me@localhost:5432/security_events

# RabbitMQ — for local development outside Docker
RABBITMQ_URL=amqp://sec_user:change-me@localhost:5672/%2F
RABBITMQ_QUEUE=security-events

# ---------------------------------------------------------------------------
# AI Provider
# ---------------------------------------------------------------------------
# Which provider to use: anthropic | gemini | github_copilot | dummy (default: anthropic)
# Use dummy for local development and rules engine testing — no API key required.
AI_PROVIDER=anthropic

# Anthropic — required when AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=your-anthropic-api-key-here
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# Gemini — required when AI_PROVIDER=gemini
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-1.5-pro

# GitHub Copilot — required when AI_PROVIDER=github_copilot
# Create a PAT at https://github.com/settings/tokens with the models:read permission
GITHUB_TOKEN=your-github-personal-access-token-here
GITHUB_COPILOT_MODEL=gpt-4o
